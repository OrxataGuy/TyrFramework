#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🧪 Ejecutando tests antes del commit..."
echo ""

# Ejecutar tests
# npm run test:smoke

# Capturar el código de salida
TEST_EXIT_CODE=$?

# Si los tests fallan, abortar el commit
if [ $TEST_EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ COMMIT ABORTADO: Los tests no pasaron"
  echo ""
  echo "💡 Soluciones:"
  echo "   1. Revisa los errores mostrados arriba"
  echo "   2. Arregla los comandos que fallan"
  echo "   3. Ejecuta 'npm run test:smoke' manualmente para verificar"
  echo "   4. Intenta hacer commit de nuevo"
  echo ""
  echo "⚠️  Para saltarte esta validación (NO RECOMENDADO):"
  echo "   git commit --no-verify -m 'tu mensaje'"
  echo ""
  exit 1
fi

echo ""
echo "✅ Tests pasados! Continuando con el commit..."
echo ""
